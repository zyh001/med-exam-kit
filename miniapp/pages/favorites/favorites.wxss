/* pages/favorites/favorites.wxss */
.page { background: var(--bg); min-height: 100vh; padding: 24rpx; }
.fav-list { display: flex; flex-direction: column; gap: 16rpx; }
.fav-item { display: flex; flex-direction: column; gap: 12rpx; }
.fav-meta { display: flex; align-items: center; gap: 12rpx; }
.fav-stem { font-size: 28rpx; line-height: 1.6; }
.q-tag { font-size: 20rpx; padding: 4rpx 12rpx; background: var(--accent-dim); color: var(--accent); border-radius: 20rpx; }
