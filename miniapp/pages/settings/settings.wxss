/* pages/settings/settings.wxss */
.page { background: var(--bg); min-height: 100vh; padding: 24rpx; }
.section { margin-bottom: 24rpx; padding: 0; }
.row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 24rpx; border-bottom: 1px solid var(--border);
}
.row:last-child { border-bottom: none; }
.row-label { font-size: 28rpx; }
.row-val { font-size: 26rpx; }
.row-arrow { color: var(--muted); font-size: 28rpx; }
.row-input { flex: 1; text-align: right; color: var(--muted); font-size: 24rpx; }
.version { text-align: center; margin-top: 48rpx; font-size: 22rpx; }
