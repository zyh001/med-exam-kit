/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 80rpx 48rpx;
  background: var(--bg);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  padding-top: 60rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 4rpx;
}

.app-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

.section {
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.input-row, .pin-row {
  display: flex;
  align-items: center;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 0 24rpx;
}

.text-input, .pin-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--text);
  background: transparent;
}

.eye-btn {
  padding: 16rpx;
  font-size: 36rpx;
}

.err-msg {
  color: var(--danger);
  font-size: 24rpx;
  margin-top: 12rpx;
  padding-left: 4rpx;
}

.login-btn {
  margin-top: 16rpx;
  width: 100%;
}

.hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  gap: 4rpx;
  font-size: 22rpx;
}
