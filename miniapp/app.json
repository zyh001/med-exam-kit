{
  "pages": [
    "pages/login/login",
    "pages/home/home",
    "pages/quiz/quiz",
    "pages/results/results",
    "pages/favorites/favorites",
    "pages/settings/settings"
  ],
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#1a2332",
    "navigationBarTitleText": "医考练习",
